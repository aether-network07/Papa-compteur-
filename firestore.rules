rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.userId == request.auth.uid &&
               data.createdAt is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidProject(request.resource.data);
      allow update: if isOwner(resource.data.userId) &&
                       isValidProject(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    // Characters
    match /characters/{characterId} {
      function isValidCharacter(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.userId == request.auth.uid;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCharacter(request.resource.data);
      allow update: if isOwner(resource.data.userId) &&
                       isValidCharacter(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    // Scripts
    match /scripts/{scriptId} {
      function isValidScript(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.userId == request.auth.uid &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidScript(request.resource.data);
      allow update: if isOwner(resource.data.userId) &&
                       isValidScript(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
